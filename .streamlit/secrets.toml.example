# Plantilla de secretos para Streamlit.
#
# LOCAL: copiá a .streamlit/secrets.toml y completá. Ese archivo está en .gitignore.
# STREAMLIT CLOUD: no subas el archivo. Pegá este contenido en
#   Manage app -> Settings -> Secrets.
#
# Ojo: la app hoy lee los CSV por upload manual y NO necesita estas credenciales.
# Solo hacen falta si corrés la ingesta (rehab_strength.ingest) desde la app.

[gcp_service_account]
type = "service_account"
project_id = "tu-project-id"
private_key_id = "..."
# El salto de línea va literal como \n dentro de las comillas.
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "nombre@tu-project-id.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."
